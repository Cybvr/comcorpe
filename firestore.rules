rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /insights/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /articles/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /blog/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /posts/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /jobs/{jobId} {
      allow read: if request.auth != null || resource.data.sharedPublicly == true;
      allow write: if request.auth != null;
    }

    match /pods/{podId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /treatmentPlans/{planId} {
      allow read: if request.auth != null || get(/databases/$(database)/documents/jobs/$(resource.data.jobSlug)).data.sharedPublicly == true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
